<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F141C"
    android:padding="20dp">

    <RelativeLayout
        android:id="@+id/headerRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp">

        <TextView
            android:id="@+id/scoreLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SCORE: 0"
            android:textColor="#388E3C"
            android:textSize="15sp"
            android:textStyle="bold"
            android:letterSpacing="0.05" />

        <Button
            android:id="@+id/btnGoManage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:backgroundTint="#1F2633"
            android:text="Manage Vault"
            android:textColor="#FFFFFF"
            android:textSize="12sp" />
    </RelativeLayout>

    <LinearLayout
        android:id="@+id/cardFrame"
        android:layout_width="match_parent"
        android:layout_height="270dp"
        android:layout_below="@id/headerRow"
        android:layout_marginTop="25dp"
        android:background="#161C26"
        android:elevation="4dp"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="25dp">

        <TextView
            android:id="@+id/statusLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:text="CARD 1 OF 20"
            android:textColor="#5C6B82"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/sideLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FRONT (QUESTION)"
            android:textColor="#1976D2"
            android:textStyle="bold"
            android:textSize="12sp"
            android:letterSpacing="0.05" />

        <TextView
            android:id="@+id/cardText"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="Sawaal Loading..."
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:lineSpacingMultiplier="1.2" />
    </LinearLayout>

    <Button
        android:id="@+id/btnFlip"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_below="@id/cardFrame"
        android:layout_marginTop="25dp"
        android:backgroundTint="#1976D2"
        android:text="Reveal Answer"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:textStyle="bold" />

    <LinearLayout
        android:id="@+id/evaluationRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/btnFlip"
        android:layout_marginTop="20dp"
        android:orientation="horizontal"
        android:weightSum="2">

        <Button
            android:id="@+id/btnWrong"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:backgroundTint="#D32F2F"
            android:text="Wrong"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnRight"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:backgroundTint="#388E3C"
            android:text="Correct"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="10dp"
        android:orientation="horizontal"
        android:weightSum="2">

        <Button
            android:id="@+id/btnPrev"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:backgroundTint="#1F2633"
            android:text="◀ Previous"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btnNext"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:backgroundTint="#1F2633"
            android:text="Next ▶"
            android:textSize="12sp" />
    </LinearLayout>

</RelativeLayout>